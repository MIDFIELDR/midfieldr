Package: midfieldr
Title: Tools and Methods for Working with MIDFIELD Data in 'R'
Version: 1.0.3.9002
Authors@R: c(
    person("Richard", "Layton", , "graphdoctor@gmail.com", role = c("cre", "aut", "cph")),
    person("Russell", "Long", role = c("aut", "cph")),
